# ---------------------------------------------------------------------------
# PostgreSQL connection string.
# Use a free Neon (https://neon.tech) or Supabase (https://supabase.com)
# Postgres database for both local dev and production.
# Do NOT use SQLite — Vercel's serverless filesystem is ephemeral.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host.neon.tech/qrtracker?sslmode=require"

# ---------------------------------------------------------------------------
# Public base URL used to build the short links that get encoded into QR codes.
# Local:  http://localhost:3000
# Prod:   https://your-app.vercel.app   (set this in Vercel's env vars)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Geo fallback provider, used for LOCAL DEV only (in production, location comes
# from Vercel's built-in geo request headers — free, no API key needed).
# Options:
#   "ipapi"  -> https://ipapi.co  (HTTPS, free tier)
#   "ip-api" -> http://ip-api.com (HTTP only, free for non-commercial)
#   "none"   -> disable the fallback entirely
# ---------------------------------------------------------------------------
GEO_FALLBACK_PROVIDER="ipapi"

# Window (in minutes) used to de-duplicate "unique" scans by IP address.
UNIQUE_SCAN_WINDOW_MINUTES="30"
